            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"productId\": {{productId}},\n  \"quantity\": 1\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "pm.test('Returns transaction with id', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.data.id).to.be.a('number');",
              "});"
            ]}
          }]
        },

        {
          "name": "[BUG-9] POST /transactions — product quantity increments instead of decrementing",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"productId\": {{productId}},\n  \"quantity\": 1\n}"
            }
          },
          "event": [{
            "listen": "prerequest",
            "script": { "exec": [
              "// Step 1: capture product quantity before the transaction",
              "const baseUrl = pm.collectionVariables.get('baseUrl');",
              "const productId = pm.collectionVariables.get('productId');",
              "pm.sendRequest(`${baseUrl}/products/${productId}`, (err, res) => {",
              "  const qty = res.json().data.quantity;",
              "  pm.collectionVariables.set('quantityBefore', qty);",
              "});"
            ]}
          },
          {
            "listen": "test",
            "script": { "exec": [
              "// Step 2: fetch product again and confirm quantity decreased",
              "const baseUrl = pm.collectionVariables.get('baseUrl');",
              "const productId = pm.collectionVariables.get('productId');",
              "const before = Number(pm.collectionVariables.get('quantityBefore'));",
              "pm.sendRequest(`${baseUrl}/products/${productId}`, (err, res) => {",
              "  const after = res.json().data.quantity;",
              "  pm.test('[BUG-9] Product quantity must decrease by 1 after transaction', () => {",
              "    pm.expect(after).to.eql(before - 1);",
              "  });",
              "});"
            ]}
          }]
        },

